# ============================================================================
# GateDoc — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# DO NOT commit .env.local to version control.
# ============================================================================

# --------------------------------------------------------------------------
# REQUIRED — Authentication
# --------------------------------------------------------------------------

# Shared password for writer login
GATEDOC_PASSWORD=your-writer-password

# Admin dashboard password (separate from writer password)
GATEDOC_ADMIN_PASSWORD=your-admin-password

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-run-openssl-rand-base64-32

# NextAuth.js URL — your app's base URL
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------------------------------------
# REQUIRED — AI Provider (at least one)
# --------------------------------------------------------------------------

# Which AI provider to use: "anthropic" (default), "openai", or "ollama"
# AI_PROVIDER=anthropic

# Anthropic API key (required if AI_PROVIDER=anthropic or unset)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required if AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Ollama settings (required if AI_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --------------------------------------------------------------------------
# OPTIONAL — Vercel KV (auto-set when KV store is linked on Vercel)
# --------------------------------------------------------------------------
# When these are absent, articles are stored in a local JSON file.

# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# --------------------------------------------------------------------------
# OPTIONAL — Template
# --------------------------------------------------------------------------

# Documentation template: "default" or "technical-docs"
# GATEDOC_TEMPLATE=default
